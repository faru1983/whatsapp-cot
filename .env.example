# ==============================================================================
# CONFIGURACIÓN PRINCIPAL DEL BOT
# Copia este archivo a .env y completa tus claves reales.
# NUNCA subas el archivo .env al repositorio.
# ==============================================================================

# Proveedor de Inteligencia Artificial activo.
# Opciones admitidas: gemini, nvidia
LLM_PROVIDER=nvidia

# Números de WhatsApp de los administradores (sin +), separados por coma.
# Reciben alertas SOS y cotizaciones confirmadas.
ADMIN_NUMBERS=56912345678

# Etiqueta de WhatsApp Business al disparar SOS (asistencia humana).
# Debe existir en Business con este nombre exacto (créala o renómbrala antes).
# Si conoces el ID interno, puedes fijarlo y se usa directo (opcional).
SOS_LABEL_NAME=Asistencia
# SOS_LABEL_ID=1
# Marcar el chat del cliente como no leído cuando hay SOS (true/false).
SOS_MARK_UNREAD=true

# ==============================================================================
# RED DE SEGURIDAD (engine.js)
# ==============================================================================

# Anti-loop: respuestas no entendidas seguidas antes de silenciar y avisar al admin.
SECURITY_MAX_CONSECUTIVE_ERRORS=3

# Cambio de intención: veces que el cliente puede alternar barriles ↔ eventos al inicio.
SECURITY_MAX_INTENT_SWITCHES=3

# ==============================================================================
# CONFIGURACIÓN DE GOOGLE (GEMINI)
# ==============================================================================
# Obtén tu API Key en: https://aistudio.google.com/
GEMINI_API_KEY=

# Modelos de Gemini (ejemplos):
# - gemini-2.5-flash
# - gemini-2.5-flash-8b
# - gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-8b

# ==============================================================================
# CONFIGURACIÓN DE NVIDIA (NIM)
# ==============================================================================
# Obtén tu API Key en: https://build.nvidia.com/
NVIDIA_API_KEY=

# Modelos de Nvidia (ejemplos):
# - meta/llama-3.1-8b-instruct
# - meta/llama-3.3-70b-instruct
# - mistralai/mistral-7b-instruct-v0.3
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
